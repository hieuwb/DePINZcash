# DePINZcash server config — copy to server/.env and edit.

# Network — where we bind and what Zcash chain we accept proofs for.
BIND_ADDR=0.0.0.0:3000
ZCASH_NETWORK=mainnet           # mainnet | testnet

# Persistence — sqlx-style URL. Default writes to ./depinzcash.sqlite next to the binary.
DATABASE_URL=sqlite://depinzcash.sqlite?mode=rwc

# Trusted Zcash JSON-RPC quorum. Comma-separated. Empty = permissive mode (proofs accepted but not verified).
# Example: TRUSTED_RPCS=http://user:pass@127.0.0.1:8232,https://rpc.example.com
TRUSTED_RPCS=

RPC_TIMEOUT=10s

# CORS — comma-separated origins for the web frontend.
CORS_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# Admin key for snapshot publish / future admin endpoints. Empty = admin endpoints return 403.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# Scheduler tickers.
SCHEDULER_ENABLED=true
HEARTBEAT_INTERVAL=60s
CHALLENGE_CHECK_INTERVAL=60s
UPTIME_REWARD_INTERVAL=300s

# Reward snapshot cadence. 0/off/false to disable cron — manual publish still works.
SNAPSHOT_INTERVAL=7d

# Verification thresholds.
MAX_HEIGHT_DRIFT=8
MAX_CLOCK_SKEW=15m

# Rate limiting on POST endpoints (per-IP token bucket).
# Tune burst higher if you're behind a CDN/proxy that collapses many clients to one IP.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=5
RATE_LIMIT_BURST=30

# Solana reward token config — surfaced to clients via /api/info.
# Until NU7 + ZIP-227 land on Zcash for custom assets, rewards pay out in this SPL token.
SPL_MINT=
SOLANA_CLUSTER=devnet

# Logging.
LOG_FORMAT=text
RUST_LOG=info,sqlx=warn,hyper=warn,tower_http=info
